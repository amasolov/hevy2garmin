# Example snippet for Home Assistant configuration.yaml
# Add this to run the Hevy->Garmin sync from PyScript on a schedule.
#
# 1. Copy this project (or at least the sync package + run_sync.py) to a path
#    your HA can execute, e.g. /config/scripts/ktmb1-fitness/
# 2. Create a Python venv there and install deps (see README), or use the
#    system Python if you've installed garth/requests there.
# 3. Allow shell_command to run the script (see Home Assistant docs for
#    allowlist_external_dirs / allowlist_external_commands if needed).
# 4. Add the shell_command below.

# --- shell_command: run sync in background (returns immediately, so no 60s timeout) ---
shell_command:
  hevy_garmin_sync: 'nohup /config/scripts/ktmb1-fitness/.venv/bin/python /config/scripts/ktmb1-fitness/run_sync.py >> /config/scripts/ktmb1-fitness/sync.log 2>&1 &'

# --- Users config ---
# All user credentials go in users.json (copy from users.json.example).
# Set hevy_api_key (from Hevy Pro settings) and garmin_email / garmin_password.
# For MFA accounts, create a garth session locally with garmin_login.py
# and set garth_session_path in users.json.
